# ============================================================================
# STAGING ENVIRONMENT CONFIGURATION
# Copy this to .env.staging and fill in your staging values
# ============================================================================

# ============================================================================
# DJANGO SETTINGS - STAGING
# ============================================================================
SECRET_KEY=<generate-with-python-manage-py-shell>
DEBUG=False
ENVIRONMENT=staging
ALLOWED_HOSTS=staging.yourdomain.com,staging-api.yourdomain.com
DJANGO_SETTINGS_MODULE=core.settings_production

# ============================================================================
# DATABASE CONFIGURATION - STAGING
# ============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=fnb_ops_staging
DB_USER=<secure-db-user>
DB_PASSWORD=<secure-db-password>
DB_HOST=mysql.staging.internal
DB_PORT=3306

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_ACCESS_LIFETIME=5
JWT_REFRESH_LIFETIME=7

# ============================================================================
# URLS & FRONTEND - STAGING
# ============================================================================
FRONTEND_URL=https://staging.yourdomain.com
VITE_API_URL=https://staging-api.yourdomain.com
CORS_ALLOWED_ORIGINS=https://staging.yourdomain.com

# ============================================================================
# EMAIL CONFIGURATION - STAGING
# ============================================================================
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=<sendgrid-api-key>
DEFAULT_FROM_EMAIL=noreply-staging@yourdomain.com

# ============================================================================
# SECURITY SETTINGS - STAGING
# ============================================================================
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=0

# ============================================================================
# LOGGING CONFIGURATION - STAGING
# ============================================================================
LOG_LEVEL=INFO
DJANGO_LOG_FILE=/var/log/fnb-ops-staging/django.log
REQUEST_LOG_FILE=/var/log/fnb-ops-staging/requests.log
ERROR_LOG_FILE=/var/log/fnb-ops-staging/errors.log
LOG_SQL=False

# ============================================================================
# SENTRY ERROR TRACKING - STAGING
# ============================================================================
SENTRY_ENABLED=True
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_SAMPLE_RATE=0.5

# ============================================================================
# FILE UPLOAD
# ============================================================================
STATIC_URL=/static/
STATIC_ROOT=/var/www/fnb-ops-staging/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/fnb-ops-staging/media

# ============================================================================
# DOCKER & DEPLOYMENT
# ============================================================================
COMPOSE_PROJECT_NAME=fnb-ops-staging
COMPOSE_FILE=docker-compose.prod.yml
