{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["manage.py", "runserver"],
      "port": 8000,
      "cwd": "${workspaceFolder}/backend"
    }
  ]
}
