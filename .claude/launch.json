{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "${workspaceFolder}/frontend",
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["manage.py", "runserver"],
      "port": 8000,
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "sky-pos",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "/Users/song/sky-pos", "run", "dev"],
      "port": 3000
    }
  ]
}
