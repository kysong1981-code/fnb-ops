# ============================================================================
# AWS Deployment Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# Django Secret Key (generate with: python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=change-me-to-a-strong-random-key

# RDS MySQL Configuration
DB_NAME=fnb_ops_db
DB_USER=admin
DB_PASSWORD=your-rds-password
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=3306

# Allowed Hosts (EC2 public IP or domain)
ALLOWED_HOSTS=your-ec2-ip,localhost,127.0.0.1

# CORS (frontend URL - same as EC2 IP for single-server setup)
CORS_ALLOWED_ORIGINS=http://your-ec2-ip

# Frontend URL
FRONTEND_URL=http://your-ec2-ip

# JWT
JWT_ACCESS_LIFETIME=60
JWT_REFRESH_LIFETIME=7

# Logging
LOG_LEVEL=INFO
