# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env.production and fill in your production values
# ============================================================================

# ============================================================================
# DJANGO SETTINGS - PRODUCTION
# ============================================================================
SECRET_KEY=<generate-with-python-manage-py-shell>
DEBUG=False
ENVIRONMENT=production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com
DJANGO_SETTINGS_MODULE=core.settings_production

# ============================================================================
# DATABASE CONFIGURATION - PRODUCTION
# ============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=fnb_ops_production
DB_USER=<secure-db-user>
DB_PASSWORD=<very-secure-db-password>
DB_HOST=mysql.production.internal
DB_PORT=3306

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_ACCESS_LIFETIME=5
JWT_REFRESH_LIFETIME=7

# ============================================================================
# URLS & FRONTEND - PRODUCTION
# ============================================================================
FRONTEND_URL=https://yourdomain.com
VITE_API_URL=https://api.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# EMAIL CONFIGURATION - PRODUCTION
# ============================================================================
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=<sendgrid-api-key>
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# SECURITY SETTINGS - PRODUCTION
# ============================================================================
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ============================================================================
# LOGGING CONFIGURATION - PRODUCTION
# ============================================================================
LOG_LEVEL=WARNING
DJANGO_LOG_FILE=/var/log/fnb-ops/django.log
REQUEST_LOG_FILE=/var/log/fnb-ops/requests.log
ERROR_LOG_FILE=/var/log/fnb-ops/errors.log
LOG_SQL=False

# ============================================================================
# SENTRY ERROR TRACKING - PRODUCTION
# ============================================================================
SENTRY_ENABLED=True
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_SAMPLE_RATE=0.1

# ============================================================================
# FILE UPLOAD
# ============================================================================
STATIC_URL=/static/
STATIC_ROOT=/var/www/fnb-ops/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/fnb-ops/media

# ============================================================================
# DOCKER & DEPLOYMENT
# ============================================================================
COMPOSE_PROJECT_NAME=fnb-ops-prod
COMPOSE_FILE=docker-compose.prod.yml
